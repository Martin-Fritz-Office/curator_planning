# Application Configuration

# Flask Environment
# Set to "production" on production servers to disable debug mode
FLASK_ENV=development

# API Keys - NEVER commit your actual keys!
# Get these from your respective API providers
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-public-key

# CORS Configuration
# Comma-separated list of allowed origins (no spaces after commas)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Server Port
PORT=5000

# Database Configuration (used by submit_survey.php and faq_admin.php)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=curator_planning
DB_USER=curator_user
DB_PASSWORD=your-secure-database-password

# Admin password hash (generate with: php -r "echo password_hash('your-password', PASSWORD_DEFAULT);")
DB_ADMIN_PASSWORD=$2y$10$your-bcrypt-hash-here

# Logging
# Set to "production" for less verbose logging
LOG_LEVEL=INFO

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=10
